  m_Script: {fileID: 11500000, guid: 1129fac58e32d8441ad5448891d2b065, type: 3}
  m_Name: DiaInstruciton3
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  lines:
  - text: "Sometimes metal cools down while you work. Cold metal cannot be shaped. 
      You can check its temperature using: get_metal_temp()  If the metal is too
      cold, heat it first.  Example:  i = 0 while i < 2:     if get_metal_temp()
      < 25:         heat()     hit()     i = i + 1  This means: If the metal is cold
      \u2192 heat it. If it is hot \u2192 hit it.  Remember: One heating lets you
      hit several times.  Be careful: Heating will later cost valuable resources.
      Use it wisely. "
    speaker: 1
    speakerName: Tod
    speakerIcon: {fileID: 21300000, guid: b20e04cbf80068d46a8b20ba31af1b1b, type: 3}
